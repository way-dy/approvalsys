rules_version = '2';

// =============================================================================
// DY 의사결정시스템 — Firestore 보안 규칙
// =============================================================================
// 핵심 원칙:
//   1) 회사 Google Workspace 도메인(@dongyeongtour.co.kr) 계정만 접근 가능
//   2) 클라이언트 측 검증과 동일한 정책을 서버에서 강제 (방어선 이중화)
//   3) accessLogs는 append-only (생성만 허용, 수정/삭제 불가)
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 공통 헬퍼: 회사 도메인 인증 사용자인지 확인 ──
    function isCompanyUser() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email is string
          && request.auth.token.email.lower().matches('.*@dongyeongtour[.]co[.]kr');
    }

    // ── 슈퍼관리자: 대외비 문서 update/delete 전권 ──
    // 클라이언트 isSuperAdmin(SUPER_ADMIN_EMAILS)과 동일 ID로 서버측 게이트.
    // 슈퍼관리자 추가 시 양쪽(이 헬퍼 + index.html SUPER_ADMIN_EMAILS) 동시 갱신.
    function isSuperAdmin() {
      return isCompanyUser()
          && request.auth.token.email.lower() == 'way@dongyeongtour.co.kr';
    }

    // ── 결재 처리 화이트리스트: submitApprovalComment가 변경하는 6필드만 허용 ──
    // 일반 결재자가 대외비 문서를 승인/반려할 때, 카테고리/본문은 못 건드리고
    // 결재 6필드만 변경하는 update를 허용하기 위한 헬퍼.
    // (1) 변경된 필드가 화이트리스트 부분집합인지, (2) 카테고리가 변하지 않는지 검사.
    function isApprovalOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['approval1Status', 'approval1Comment',
                        'approval2Status', 'approval2Comment',
                        'finalApprovalDate', 'rejectionAckedBy'])
          && request.resource.data.category == resource.data.category;
    }

    // ── 본 문서의 1·2차 결재자 본인 여부 ──
    function isApproverForDoc() {
      return resource.data.approver1Email == request.auth.token.email
          || resource.data.approver2Email == request.auth.token.email;
    }

    // ── 기안 본문 (drafts) ──
    // 회사 사용자: read/create 허용. update 게이트:
    //   (1) 비-대외비는 기존대로 누구나 (대외비로의 카테고리 변경 차단)
    //   (2) 슈퍼관리자는 대외비 전권
    //   (3) 대외비 결재 처리: 결재자 본인이 결재 6필드만 변경(카테고리 불변)
    // delete는 슈퍼관리자만(변경 없음).
    // resource.data == 기존 문서, request.resource.data == 새 문서.
    match /drafts/{docId} {
      // 🔒 대외비 보안 (2026-06-30): read 에 대외비 게이트 추가.
      //   과거 사고 — read 가 isCompanyUser 무조건 허용이라 일반직원이 콘솔/SDK 로
      //   대외비 본문(content)·첨부 URL 까지 직접 조회 가능했음(본 시스템이 진원지로 추정).
      //   보관용·곧 클로징이라 대외비 조회는 권한자(기안자/1·2차결재자/슈퍼)에게만 — 4종 화이트리스트.
      //   목록(drafts_index)은 대외비 퍼지 + 주입차단으로 자연 소멸. 광역 본체쿼리는 앱이 .catch 로 degrade.
      //   회귀 가드: 대외비 read 를 isCompanyUser 무조건으로 되돌리는 변경 금지(누출 재발).
      allow read:   if isCompanyUser() && (
                      resource.data.category != '대외비'
                      || isSuperAdmin()
                      || resource.data.drafterEmail == request.auth.token.email
                      || resource.data.approver1Email == request.auth.token.email
                      || resource.data.approver2Email == request.auth.token.email
                    );
      // 🚫 신규 기안 생성 차단 (2026-06-30 컷오버) — 기안은 OPS(dy-ops)로 이전.
      //   레거시에서 새 기안 만들면 dyops와 데이터 갈라져 혼선 → create 봉쇄.
      //   조회(read)·기존 기안 결재(update)는 유지(보관·진행분 마무리).
      allow create: if false;
      allow update: if isCompanyUser()
                    && (
                      (resource.data.category != '대외비'
                        && request.resource.data.category != '대외비')
                      || isSuperAdmin()
                      || (resource.data.category == '대외비'
                          && isApproverForDoc()
                          && isApprovalOnlyUpdate())
                    );
      allow delete: if isCompanyUser()
                    && (resource.data.category != '대외비' || isSuperAdmin());
    }

    // ── 기안 인덱스 (drafts_index) ──
    // drafts와 동일 정책. 모든 drafts 쓰기 시 함께 갱신되는 mirror.
    match /drafts_index/{docId} {
      // 🔒 대외비 보안 (2026-06-30): 미러(목록/검색)는 도메인 전체 read 라 대외비를 담지 않는다.
      //   기존 대외비 미러는 scripts/purge-confidential-index.cjs 로 1회 퍼지.
      //   create/update 는 대외비 카테고리 주입 차단(입력 동결이 배너뿐이라도 재유입 방지).
      //   delete 는 퍼지/전환 위해 허용. read 는 도메인 전체 유지(퍼지 후 대외비 0건).
      allow read:   if isCompanyUser();
      allow create, update: if isCompanyUser()
                    && request.resource.data.category != '대외비';
      allow delete: if isCompanyUser();
    }

    // ── 메타데이터 (사용자 목록, 수리비 맵, 카운터) ──
    // 회사 사용자 모두 읽기/쓰기 가능 (counters는 generateDocId 트랜잭션에서 필요).
    match /meta/{docId} {
      allow read, write: if isCompanyUser();
    }

    // ── 접근 감사 로그 (accessLogs) ──
    // 생성만 허용 (append-only). 수정/삭제는 어떤 클라이언트도 불가.
    // 본인 이메일이 viewer 필드와 일치해야 위조 방지.
    match /accessLogs/{logId} {
      allow create: if isCompanyUser()
                   && request.resource.data.viewer == request.auth.token.email;
      allow read:   if isCompanyUser();
      allow update, delete: if false;
    }

    // ── 그 외 모든 경로 차단 (기본 거부) ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
